# Copy to .env and adjust.
# Local Mongo:  mongodb://127.0.0.1:27017/tower_tracker
# Atlas:        mongodb+srv://user:pass@cluster.mongodb.net/tower_tracker
MONGO_URI=mongodb://127.0.0.1:27017/tower_tracker
JWT_SECRET=change_this_to_a_long_random_string
PORT=5050

# Comma-separated origins allowed to call the API (the three frontends).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Cloudinary — sign up at https://cloudinary.com and fill these in.
# Leave blank to store images as base64 in MongoDB (dev fallback).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
