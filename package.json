{
  "name": "tower-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Drone-as-a-Service powerline tower tracking — backend + client/pilot/admin frontends",
  "scripts": {
    "dev": "concurrently -n backend,client,pilot,admin -c blue,green,magenta,yellow \"npm:dev:backend\" \"npm:dev:client\" \"npm:dev:pilot\" \"npm:dev:admin\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:client": "npm --prefix client-app run dev",
    "dev:pilot": "npm --prefix pilot-app run dev",
    "dev:admin": "npm --prefix admin-app run dev",
    "seed": "npm --prefix backend run seed",
    "test": "node backend/test/smoke.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
