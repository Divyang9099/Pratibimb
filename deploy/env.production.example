# Copy this to backend/.env ON THE EC2 SERVER and fill in real values.
# Do NOT commit the filled-in version.

MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/tower_tracker
JWT_SECRET=replace_with_a_long_random_string
PORT=5050

# Exact origins of your three deployed frontends (comma-separated, no spaces).
# Update these to wherever client/pilot/admin apps are actually served from.
CORS_ORIGINS=https://varunaat.in,https://www.varunaat.in

# Seed credentials — only needed if you run `npm run seed`, which WIPES every
# collection. Never hardcode these in seed.js; this repo is public.
SEED_ADMIN_NAME=Admin
SEED_ADMIN_LOGIN=
SEED_ADMIN_PASSWORD=
SEED_PILOT_NAME=Pilot
SEED_PILOT_LOGIN=
SEED_PILOT_PASSWORD=
SEED_PILOT_PHONE=

# Cloudinary (leave blank to fall back to base64-in-Mongo, not recommended in prod)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
